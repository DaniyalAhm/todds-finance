# Copy this file to .env and replace the required values.
# ACTUAL_PASSWORD is also used to sign frontend login sessions.
ACTUAL_PASSWORD=replace-me

# Optional Actual Budget connection settings. These can also be entered in the UI.
ACTUAL_SERVER_URL=http://host.docker.internal:5006
ACTUAL_SYNC_ID=

# Optional Open WebUI-compatible AI endpoint settings.
AI_SERVER_URL=
AI_API_KEY=
AI_MODEL=gemma4:e4b

# Host-facing URLs and ports. PUBLIC_BACKEND_URL is embedded at frontend build time.
PUBLIC_BACKEND_URL=http://localhost:3010
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_PORT=3000
BACKEND_PORT=3010
ML_BACKEND_PORT=5000
AUTH_USERNAME=Authenticated user
